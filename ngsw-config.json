{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    },
    {
      "name": "i18n",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/i18n/*.json"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-index",
      "urls": [
        "https://thaqalayndata.netlify.app/index/**"
      ],
      "cacheConfig": {
        "maxSize": 50,
        "maxAge": "7d",
        "strategy": "freshness",
        "timeout": "3s"
      }
    },
    {
      "name": "api-books",
      "urls": [
        "https://thaqalayndata.netlify.app/books/**"
      ],
      "cacheConfig": {
        "maxSize": 500,
        "maxAge": "30d",
        "strategy": "freshness",
        "timeout": "5s"
      }
    },
    {
      "name": "api-people",
      "urls": [
        "https://thaqalayndata.netlify.app/people/**"
      ],
      "cacheConfig": {
        "maxSize": 200,
        "maxAge": "30d",
        "strategy": "freshness",
        "timeout": "5s"
      }
    },
    {
      "name": "google-fonts",
      "urls": [
        "https://fonts.googleapis.com/**",
        "https://fonts.gstatic.com/**"
      ],
      "cacheConfig": {
        "maxSize": 20,
        "maxAge": "365d",
        "strategy": "freshness",
        "timeout": "3s"
      }
    }
  ]
}
